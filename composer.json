{
    "name": "vite-gourmand/app",
    "description": "Application de commande traiteur - Vite & Gourmand",
    "type": "project",
    "require": {
        "php": "^8.3",
        "phpmailer/phpmailer": "^6.9",
        "mongodb/mongodb": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\":       "src/Core/",
            "Controller\\": "src/Controller/",
            "Service\\":    "src/Service/",
            "Repository\\": "src/Repository/",
            "Entity\\":     "src/Entity/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
