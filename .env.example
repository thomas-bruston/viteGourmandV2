
# VITE & GOURMAND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

APP_ENV=development
APP_URL=http://localhost:8080

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=viteGourmand
MYSQL_USER=vg_app
MYSQL_PASSWORD=vg_app_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ---- MongoDB ----
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpassword
MONGO_DATABASE=viteGourmandStats
MONGO_HOST=mongo
MONGO_PORT=27017

# ---- Mail (PHPMailer / SMTP) ----
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@vitegourmand.fr
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=noreply@vitegourmand.fr
MAIL_FROM_NAME="Vite & Gourmand"
MAIL_ENCRYPTION=tls

# ---- Sécurité ----
# Clé pour les tokens CSRF (32 caractères aléatoires)
APP_SECRET=changeme_generate_a_random_32_char_string
